# ============================================================
# MANDEA — Lokale Umgebungsvariablen
# Kopiere diese Datei zu ".env" und fülle die Werte aus.
# Die .env-Datei wird NIEMALS ins Git committet.
# ============================================================

# Admin-Passwort (beliebiger langer String)
ADMIN_SECRET=hier_ein_langes_geheimes_passwort

# GitHub API — zum Lesen/Schreiben von products.json & Fotos
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=mandea-shop
GITHUB_REPO=mandea
GITHUB_BRANCH=main

# Stripe — für lokale Tests den TEST-Key verwenden (sk_test_...)
# Den Live-Key (sk_live_...) nur in Netlify setzen, nie lokal!
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
