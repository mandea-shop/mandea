# ============================================================
# MANDEA — Umgebungsvariablen
#
# 1. Diese Datei kopieren: cp .env.example .env
# 2. .env NIEMALS committen (steht bereits in .gitignore)
# 3. Für Netlify: Variablen im Dashboard unter
#    Site settings → Environment variables eintragen
# ============================================================

# Stripe Secret Key
# Test:  sk_test_...  (aus dashboard.stripe.com → API-Schlüssel)
# Live:  sk_live_...  (erst nach Stripe-Konto-Verifizierung)
STRIPE_SECRET_KEY=sk_test_HIER_DEINEN_KEY_EINTRAGEN

# Admin-Passwort (frei wählbar, mindestens 12 Zeichen empfohlen)
ADMIN_PASSWORD=SICHERES_PASSWORT_HIER

# Admin-Token-Secret (zufälliger langer String — einmal generieren und nie ändern)
# Generieren mit: openssl rand -hex 32
ADMIN_SECRET=ZUFAELLIGER_STRING_HIER

# GitHub-Zugangsdaten (für Admin → Produkte speichern)
# Token erstellen: github.com → Settings → Developer settings → Fine-grained tokens
# Berechtigungen: Repository → Contents → Read & Write
GITHUB_TOKEN=github_pat_HIER_EINTRAGEN
GITHUB_OWNER=DEIN_GITHUB_BENUTZERNAME
GITHUB_REPO=mandea
GITHUB_BRANCH=main
